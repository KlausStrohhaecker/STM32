set(CMAKE_SYSTEM_NAME Generic)
set(CMAKE_SYSTEM_PROCESSOR ARM)

find_program(ARM_C_COMPILER NAMES arm-none-eabi-gcc REQUIRED)
find_program(ARM_CXX_COMPILER NAMES arm-none-eabi-g++ REQUIRED)
find_program(ARM_ASM_COMPILER NAMES arm-none-eabi-gcc REQUIRED)

set(CMAKE_C_COMPILER ${ARM_C_COMPILER} CACHE FILEPATH "C compiler" FORCE)
set(CMAKE_CXX_COMPILER ${ARM_CXX_COMPILER} CACHE FILEPATH "C++ compiler" FORCE)
set(CMAKE_ASM_COMPILER ${ARM_ASM_COMPILER} CACHE FILEPATH "ASM compiler" FORCE)
set(CMAKE_OBJCOPY arm-none-eabi-objcopy CACHE FILEPATH "OBJCOPY" FORCE)
set(CMAKE_OBJDUMP arm-none-eabi-objdump CACHE FILEPATH "OBJDUMP" FORCE)
set(CMAKE_SIZE arm-none-eabi-size CACHE FILEPATH "SIZE" FORCE)
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY CACHE STRING "TRY_COMPILE_TARGET_TYPE" FORCE)
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER CACHE STRING "FIND_ROOT_PATH_MODE_PROGRAM" FORCE)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY CACHE STRING "FIND_ROOT_PATH_MODE_INCLUDE" FORCE)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY CACHE STRING "FIND_ROOT_PATH_MODE_PACKAGE" FORCE)
set(MCU_FLAGS "-mcpu=cortex-m4 -mthumb -mfpu=fpv4-sp-d16 -mfloat-abi=hard")
set(CMAKE_C_FLAGS "${MCU_FLAGS} -Wall -fdata-sections -ffunction-sections --specs=nosys.specs --specs=nano.specs" CACHE STRING "C_FLAGS" FORCE)
set(CMAKE_CXX_FLAGS "${MCU_FLAGS} -Wall -fdata-sections -ffunction-sections --specs=nosys.specs --specs=nano.specs -fno-exceptions -fno-rtti" CACHE STRING "CXX_FLAGS" FORCE)
set(CMAKE_ASM_FLAGS "${MCU_FLAGS} -x assembler-with-cpp" CACHE STRING "ASM_FLAGS" FORCE)
set(CMAKE_C_FLAGS_DEBUG "-O0 -g -gdwarf-2" CACHE STRING "C_FLAGS_DEBUG" FORCE)
set(CMAKE_CXX_FLAGS_DEBUG "-O0 -g -gdwarf-2" CACHE STRING "CXX_FLAGS_DEBUG" FORCE)
set(CMAKE_C_FLAGS_RELEASE "-O3 -flto" CACHE STRING "C_FLAGS_RELEASE" FORCE)
set(CMAKE_CXX_FLAGS_RELEASE "-O3 -flto" CACHE STRING "CXX_FLAGS_RELEASE" FORCE)
set(CMAKE_C_FLAGS_MINSIZEREL "-Os" CACHE STRING "C_FLAGS_MINSIZEREL" FORCE)
set(CMAKE_CXX_FLAGS_MINSIZEREL "-Os" CACHE STRING "CXX_FLAGS_MINSIZEREL" FORCE)
set(CMAKE_C_FLAGS_RELWITHDEBINFO "-O2 -g -gdwarf-2" CACHE STRING "C_FLAGS_RELWITHDEBINFO" FORCE)
set(CMAKE_CXX_FLAGS_RELWITHDEBINFO "-O2 -g -gdwarf-2" CACHE STRING "CXX_FLAGS_RELWITHDEBINFO" FORCE)

